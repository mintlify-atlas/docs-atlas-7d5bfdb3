  "keyFeatures": [
    "TypeScript utilities for Discord.js bot development",
    "Extended Discord events and UI components",
    "Canvas manipulation with gradients and filters",
    "Minecraft API integrations (skins, server status, Mojang API)",
    "General-purpose utilities (date, validation, formatting, math)",
    "Monorepo architecture with modular packages"
  ],
  "publicApiSurface": [
    "@magicyan/core - hexToRgb, rgbToHex, formatDate, isValidUrl, sleep, withTimeout",
    "@magicyan/discord - findCommand, commandMention, createEmbed, createButton, createModal",
    "@magicyan/discord-events - Extended event handlers for Discord.js",
    "@magicyan/discord-ui - UI components for Discord messages",
    "@magicyan/canvas - Font class, createGradient, applyFilters",
    "@magicyan/minecraft - fetchSkin, fetchServerStatus, mojangAPI"
  ]
